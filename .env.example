# ===========================================
# 校园二手交易平台 - 环境变量模板
# 复制为 .env 并填入真实值
# ===========================================

# 数据库
CAMPUS_DATASOURCE_HOST=localhost
CAMPUS_DATASOURCE_PORT=3306
CAMPUS_DATASOURCE_DATABASE=campus_trading
CAMPUS_DATASOURCE_USERNAME=root
CAMPUS_DATASOURCE_PASSWORD=your_db_password

# Redis
CAMPUS_REDIS_HOST=localhost
CAMPUS_REDIS_PORT=6379
CAMPUS_REDIS_PASSWORD=your_redis_password
CAMPUS_REDIS_DATABASE=10

# 阿里云 OSS
CAMPUS_ALIOSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
CAMPUS_ALIOSS_ACCESS_KEY_ID=your_access_key_id
CAMPUS_ALIOSS_ACCESS_KEY_SECRET=your_access_key_secret
CAMPUS_ALIOSS_BUCKET_NAME=your_bucket_name

# JWT（可选）
# CAMPUS_JWT_ADMIN_SECRET_KEY=your_admin_key
# CAMPUS_JWT_USER_SECRET_KEY=your_user_key

# 微信
CAMPUS_WECHAT_APPID=your_wechat_appid
CAMPUS_WECHAT_SECRET=your_wechat_secret
